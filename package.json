{
  "name": "gai",
  "version": "1.0.0",
  "description": "Minimal Git + AI CLI tool",
  "type": "module",
  "bin": {
    "gai": "./dist/gai.js"
  },
  "scripts": {
    "build": "tsup bin/gai.js --format esm --clean",
    "dev": "tsup bin/gai.js --format esm --watch"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "axios": "^1.7.0",
    "commander": "^12.1.0",
    "enquirer": "^2.4.1",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
